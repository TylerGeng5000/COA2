// Memory image for the course example: sum 1..100
// Uses readmemh format with address directives.
// Instruction encoding: [15:8]=opcode, [7:0]=addr

@00
02A0  // LOAD A0
01A4  // STORE A4
02A2  // LOAD A2
01A3  // STORE A3
02A4  // LOOP: LOAD A4
03A3  // ADD A3
01A4  // STORE A4
02A3  // LOAD A3
04A1  // SUB A1
01A3  // STORE A3
0504  // JMPGEZ 04
0700  // HALT (opcode 07, addr ignored)

@A0
0000  // A0 = 0
0001  // A1 = 1
0064  // A2 = 100
0000  // A3 (temp)
0000  // A4 (sum)
